@model IEnumerable<BudgetTracker.Core.DTOs.IncomeDto>

@{
    ViewData["Title"] = "Income Dashboard";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h1 class="mb-0">@ViewData["Title"]</h1>
    <button type="button" class="btn btn-primary" data-bs-toggle="modal" data-bs-target="#addIncomeModal">Add New Income</button>
</div>

<div class="card shadow-sm mb-4">
    <div class="card-body">
        <div class="row g-3 align-items-end">
            <div class="col-md-3">
                <label class="form-label fw-semibold">Income Source</label>
                <select id="source" class="form-select">
                    <option value="">All Sources</option>
                    @foreach (var s in ViewBag.Sources)
                    {
                        <option value="@s">@s</option>
                    }
                </select>
            </div>

            <div class="col-md-3">
                <label class="form-label">Income Description</label>
                <input type="text" id="description" class="form-control" placeholder="Enter description" />
            </div>

            <div class="col-md-2">
                <label class="form-label fw-semibold">From Date</label>
                <input type="date" id="startDate" class="form-control" />
            </div>

            <div class="col-md-2">
                <label class="form-label fw-semibold">To Date</label>
                <input type="date" id="endDate" class="form-control" />
            </div>

            <div class="col-md-2 d-flex justify-content-end">
                <button id="filterBtn" class="btn btn-outline-primary me-2">
                    <i class="bi bi-search"></i> Filter
                </button>
                <button id="clearBtn" class="btn btn-outline-secondary">
                    <i class="bi bi-arrow-clockwise"></i> Clear
                </button>
            </div>
        </div>
    </div>
</div>

<div id="incomeTableContainer">
    <partial name="_IncomeTablePartial" model="Model" />
</div>

<div class="modal fade"
     id="addIncomeModal"
     tabindex="-1"
     aria-labelledby="addIncomeModalLabel"
     aria-hidden="true">

    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="addIncomeModalLabel"> New Income </h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>

            <div class="modal-body">
                <partial name="_CreateModal" model="new BudgetTracker.Core.DTOs.IncomeDto()" />
            </div>
        </div>
    </div>
</div>

<div class="modal fade"
     id="editModal"
     tabindex="-1"
     aria-labelledby="editModalLabel"
     aria-hidden="true">

    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="editModalLabel"> Edit Income </h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>

            <div class="modal-body">
                <div id="editIncomeContainer">
                    Loading...
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        var currentSource = $('#source').val();
        var currentDescription = $('#description').val();
        var currentStartDate = $('#startDate').val();
        var currentEndDate = $('#endDate').val();

        // Function to load filtered data via AJAX
        function loadFilteredData(source, description, startDate, endDate) {
               $.ajax({
                   url: '@Url.Action("Filter", "Income")',
                   type: 'GET',
                   data: { source: source, description: description, startDate: startDate, endDate: endDate },
                   success: function (result) {
                       $('#incomeTableContainer').html(result);
                       // Update current filter values
                        currentSource = source;
                        currentDescription = description;
                        currentStartDate = startDate;
                        currentEndDate = endDate;
                        // Toggle "Filtered" label visibility
                        if (source || description || startDate || endDate) {
                            $('#filteredLabel').removeClass('d-none');
                        } else {
                            $('#filteredLabel').addClass('d-none');
                        }
                   },
                   error: function () {
                       alert('Error loading data.');
                   }
               });
           }

        // Trigger filter
        $('#filterBtn').on('click', function (e) {
            e.preventDefault();
            var source = $('#source').val();
            var description = $('#description').val();
            var startDate = $('#startDate').val();
            var endDate = $('#endDate').val();
            if (source === currentSource && 
                description === currentDescription && 
                startDate === currentStartDate && 
                endDate === currentEndDate) {
                return; // No changes in filters
            }
            loadFilteredData(source, description, startDate, endDate);
        });

        // Clear filters
        $('#clearBtn').on('click', function (e) {
            e.preventDefault();
            $('#source').val('');
            $('#description').val('');
            $('#startDate').val('');
            $('#endDate').val('');

            // No filters to clear.
            if (!currentSource && !currentDescription && !currentStartDate && !currentEndDate) {
                return;
            }
            loadFilteredData('', '', '', '');
        });

        // Load edit form in modal
        $('#editModal').on('show.bs.modal', function (event) {
            var button = $(event.relatedTarget);
            var incomeId = button.data('id');
            var container = $('#editIncomeContainer');
            container.html('Loading...');

            $.ajax({
                url: '@Url.Action("EditModal", "Income")',
                type: 'GET',
                data: { id: incomeId },
                success: function (result) {
                    container.html(result);
                },
                error: function () {
                    container.html('Error loading form.');
                }
            });
        });
    </script>
}