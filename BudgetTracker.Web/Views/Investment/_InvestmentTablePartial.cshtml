@model IEnumerable<BudgetTracker.Core.DTOs.InvestmentDto>

@{
    var totalFilteredInvestment = Model.Sum(i => i.Amount);
}
<div class="alert alert-secondary">
    <strong>Total <span id="filteredLabel" class="d-none">Filtered</span> Investment:</strong> @totalFilteredInvestment.ToString("C")
</div>

<table class="table table-striped table-hover">
    <thead class="table-dark">
        <tr>
            <th>
                Type
            </th>
            <th>
                @Html.DisplayNameFor(model => model.Amount)
            </th>
            <th>
                Date Invested
            </th>
            <th>
                Current Value
            </th>
            <th>Actions</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td>@item.Tag?.Name</td>
                <td>@item.Amount.ToString("C")</td>
                <td>@item.DateInvested.ToShortDateString()</td>
                <td>@item.CurrentValue.ToString("C")</td>
                <td>
                    <a class="btn btn-sm btn-secondary" asp-action="Edit" asp-route-id="@item.Id" title="Edit"><i class="bi bi-pencil-square"></i></a>
                    <a class="btn btn-sm btn-secondary" asp-action="Details" asp-route-id="@item.Id" title="Details"><i class="bi bi-search"></i></a>
                    <a class="btn btn-sm btn-danger" asp-action="Delete" asp-route-id="@item.Id" title="Delete"><i class="bi bi-trash3"></i></a>
                </td>
            </tr>
        }
    </tbody>
</table>