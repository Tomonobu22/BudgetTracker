@model BudgetTracker.Core.DTOs.InvestmentDto

<form asp-action="Create">
    <input type="hidden" id="newTagName" name="newTagName" />
    <div asp-validation-summary="ModelOnly" class="text-danger"></div>

    <div class="mb-3 row align-items-center">
        <label class="col-sm-4 col-form-label text-end pe-3"><strong>Type:</strong></label>
        <div class="col-sm-8">
            <select asp-for="TagId" class="form-control" asp-items="ViewBag.Tags"></select>
        </div>
        <span asp-validation-for="TagId" class="text-danger"></span>
    </div>

    <div class="mb-3 row align-items-center">
        <label class="col-sm-4 col-form-label text-end pe-3"><strong>Amount:</strong></label>
        <div class="col-sm-8">
            <input asp-for="Amount" class="form-control" placeholder="Enter amount" />
            <span asp-validation-for="Amount" class="text-danger"></span>
        </div>
    </div>

    <div class="mb-3 row align-items-center">
        <label class="col-sm-4 col-form-label text-end pe-3"><strong>Date Invested:</strong></label>
        <div class="col-sm-8">
            <input asp-for="DateInvested" type="date" value="@DateTime.Now.ToString("yyyy-MM-dd")" class="form-control" />
            <span asp-validation-for="DateInvested" class="text-danger"></span>
        </div>
    </div>

    <div class="mb-3 row align-items-center">
        <label class="col-sm-4 col-form-label text-end pe-3"><strong>Current Value:</strong></label>
        <div class="col-sm-8">
            <input asp-for="CurrentValue" class="form-control" placeholder="Enter current value" />
            <span asp-validation-for="CurrentValue" class="text-danger"></span>
        </div>
    </div>

    <div class="mt-3 d-flex justify-content-end">
        <button type="submit" class="btn btn-success me-2">Add</button>
        <a asp-action="Index" class="btn btn-secondary me-2">Cancel</a>
    </div>
</form>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
