@model IEnumerable<BudgetTracker.Core.DTOs.InvestmentDto>

@{
    ViewData["Title"] = "Investment Dashboard";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h1 class="mb-0">@ViewData["Title"]</h1>
    <button type="button" class="btn btn-primary" data-bs-toggle="modal" data-bs-target="#addInvestmentModal">Add New Investment</button>
</div>

<div class="card shadow-sm mb-4">
    <div class="card-body">
        <div class="row g-3 align-items-end">
            <div class="col-md-3">
                <label class="form-label fw-semibold">Investment Type</label>
                <select id="type" class="form-select">
                    <option value="">All Types</option>
                    @foreach (var s in ViewBag.Types)
                    {
                        <option value="@s">@s</option>
                    }
                </select>
            </div>

            <div class="col-md-3">
                <label class="form-label fw-semibold">From Date</label>
                <input type="date" id="startDate" class="form-control" />
            </div>

            <div class="col-md-3">
                <label class="form-label fw-semibold">To Date</label>
                <input type="date" id="endDate" class="form-control" />
            </div>

            <div class="col-md-3 d-flex justify-content-end">
                <button id="filterBtn" class="btn btn-outline-primary me-2">
                    <i class="bi bi-search"></i> Filter
                </button>
                <button id="clearBtn" class="btn btn-outline-secondary">
                    <i class="bi bi-arrow-clockwise"></i> Clear
                </button>
            </div>
        </div>
    </div>
</div>

<div id="investmentTableContainer">
    <partial name="_InvestmentTablePartial" model="Model" />
</div>

<div class="modal fade" id="addInvestmentModal" tabindex="-1" aria-labelledby="addInvestmentModalLabel" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="addInvestmentModalLabel">Add New Investment</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                <partial name="_CreateModal" model="new BudgetTracker.Core.DTOs.InvestmentDto()" />
            </div>
        </div>
    </div>
</div>

<div class="modal fade" id="editModal" tabindex="-1" aria-labelledby="editModalLabel" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="editModalLabel">Edit Investment</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                <div id="editInvestmentContainer">
                    Loading...
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        var currentType = $('#type').val();
        var currentStartDate = $('#startDate').val();
        var currentEndDate = $('#endDate').val();

        // Function to load filtered data via AJAX
        function loadFilteredData(type, startDate, endDate) {
               $.ajax({
                   url: '@Url.Action("Filter", "Investment")',
                   type: 'GET',
                   data: { type: type, startDate: startDate, endDate: endDate },
                   success: function (result) {
                       $('#investmentTableContainer').html(result);
                       // Update current filter values
                        currentType = type;
                        currentStartDate = startDate;
                        currentEndDate = endDate;
                        // Toggle "Filtered" label visibility
                        if (type || startDate || endDate) {
                            $('#filteredLabel').removeClass("d-none");
                        } else {
                            $('#filteredLabel').addClass("d-none");
                        }
                   },
                   error: function () {
                       alert('Error loading data.');
                   }
               });
           }

        // Trigger filter
        $('#filterBtn').on('click', function (e) {
            e.preventDefault();
            var type = $('#type').val();
            var startDate = $('#startDate').val();
            var endDate = $('#endDate').val();
            if (type === currentType && startDate === currentStartDate && endDate === currentEndDate) {
                return; // No changes in filters
            }
            loadFilteredData(type, startDate, endDate);
        });

        // Clear filters
        $('#clearBtn').on('click', function (e) {
            e.preventDefault();
            $('#type').val('');
            $('#startDate').val('');
            $('#endDate').val('');

            // No filters to clear.
            if (!currentType && !currentStartDate && !currentEndDate) {
                return;
            }
            loadFilteredData('', '', '');
        });

        // Load edit form in modal
        $('#editModal').on('show.bs.modal', function (event) {
            var button = $(event.relatedTarget);
            var investmentId = button.data('id');
            var container = $('#editInvestmentContainer');
            container.html('Loading...');

            $.ajax({
                url: '@Url.Action("EditModal", "Investment")',
                type: 'GET',
                data: { id: investmentId },
                success: function (result) {
                    container.html(result);
                },
                error: function () {
                    container.html('Error loading data.');
                }
            });
        });
    </script>
}