@using BudgetTracker.Core.Enums
@model IEnumerable<BudgetTracker.Core.DTOs.ImportDto>
@{
    ViewData["Title"] = "Imports";
}

<div>
    <h1>Imports</h1>
    <p>Manage your financial data imports. Currently, only csv files are accepted.</p>
</div>

@if(ViewBag.Message != null)
{
    <div class="alert alert-success">
        @ViewBag.Message
    </div>
}
@if(!ViewData.ModelState.IsValid)
{
    <div class="alert alert-danger">
        Please upload a valid CSV file.
    </div>
}
 
<div class="card shadow-sm">
    <div class="card-header">
        <h5 class="mb-0">File Upload</h5>
    </div>

    <div class="card-body">
        <form asp-action="ImportCsv" method="post" enctype="multipart/form-data">
            <div class="row align-items-end g-3">
                <div class="col-md-5">
                    <label for="file" class="form-label">CSV File</label>
                    <input type="file"
                           class="form-control"
                           id="file"
                           name="file"
                           accept=".csv"
                           required />
                </div>
                <div class="col-md-4">
                    <label for="importType" class="form-label">
                        Import Type
                    </label>
                    <select class="form-select"
                            id="importType"
                            name="importType"
                            required>
                        <option value="" selected disabled>
                            Choose a type...
                        </option>
                        @foreach (RecordType type in Enum.GetValues(typeof(RecordType)))
                        {
                            <option value="@type">@type</option>
                        }
                    </select>
                </div>
                <div class="col-md-3">
                    <button type="submit" class="btn btn-primary w-100">
                        Upload & Import
                    </button>
                </div>
            </div>
        </form>
    </div>
</div>

<div class="card shadow-sm mt-4">
    <div class="card-header d-flex justify-content-between align-items-center">
        <h5 class="mb-0">Import History</h5>
        <span class="text-muted small">Previous CSV imports</span>
    </div>

    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-hover mb-0">
                <thead class="table-light">
                    <tr>
                        <th>File Name</th>
                        <th>Type</th>
                        <th>Status</th>
                        <th>Uploaded</th>
                        <th>Processed</th>
                        <th></th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model.Any())
                    {
                        foreach (var import in Model)
                        {
                            <tr>
                                <td>
                                    @import.FileName
                                </td>
                                <td>
                                    @import.ImportType
                                </td>
                                <td>
                                    @switch (import.Status)
                                    {
                                        case ImportStatus.Completed:
                                            <span class="badge bg-success">
                                                Completed
                                            </span>
                                            break;

                                        case ImportStatus.InProgress:
                                            <span class="badge bg-primary">
                                                Processing
                                            </span>
                                            break;

                                        case ImportStatus.Failed:
                                            <span class="badge bg-danger">
                                                Failed
                                            </span>
                                            break;

                                        default:
                                            <span class="badge bg-secondary">
                                                Pending
                                            </span>
                                            break;
                                    }
                                </td>
                                <td>
                                    @import.UploadedAt.ToLocalTime().ToString("g")
                                </td>
                                <td>
                                    @(import.ProcessedAt.HasValue
                                                                ? import.ProcessedAt.Value.ToLocalTime().ToString("g")
                                                                : "-")
                                </td>
                                <td class="text-end">
                                    <a asp-action="Details"
                                       asp-route-id="@import.Id"
                                        class="btn btn-sm btn-outline-secondary">
                                        View
                                    </a>
                                    <form asp-action="Delete"
                                          asp-route-id="@import.Id"
                                          method="post"
                                          class="d-inline">
                                        <button type="submit"
                                                class="btn btn-sm btn-outline-danger"
                                                onclick="return confirm('Are you sure you want to delete this import?');">
                                            Delete
                                        </button>
                                        </form>
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="6" class="text-center text-muted py-4">
                                No imports found.
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>
