@model MonthlySummaryViewModel

@{
    ViewData["Title"] = "Home Page";
    var years = ViewBag.AvailableYears as List<int>;
}

<link rel="stylesheet" href="~/css/home.css" />
<script type="text/javascript" src="https://www.gstatic.com/charts/loader.js"></script>

<!-- Year selector -->
<div class="text-center mb-4">
    <form method="get" id="yearForm" class="d-inline-block">
        <select asp-for="Year"
                asp-items="@(new SelectList(years, Model.Year))"
                id="yearSelect"
                class="form-select form-select-lg text-center"
                style="width: 150px;"
                onchange="this.form.submit()">
        </select>
    </form>
</div>

<div class="container-fluid">

    <!-- Summary Cards -->
    <div class="row g-3 mb-4">

        <div class="col-md-4">
            <div class="card text-white bg-success shadow-sm h-100">
                <div class="card-body">
                    <h6 class="card-title text-uppercase">Total Income @Model.Year</h6>
                    <h3 class="fw-bold">@Model.TotalIncome.ToString("C")</h3>
                    <a href="@Url.Action("Index", "Income")" class="btn btn-light btn-sm mt-2">View Details</a>
                </div>
            </div>
        </div>

        <div class="col-md-4">
            <div class="card text-white bg-danger shadow-sm h-100">
                <div class="card-body">
                    <h6 class="card-title text-uppercase">Total Expenses @Model.Year</h6>
                    <h3 class="fw-bold">@Model.TotalExpenses.ToString("C")</h3>
                    <a href="@Url.Action("Index", "Expense")" class="btn btn-light btn-sm mt-2">View Details</a>
                </div>
            </div>
        </div>

        <div class="col-md-4">
            <div class="card text-white bg-secondary shadow-sm h-100">
                <div class="card-body">
                    <h6 class="card-title text-uppercase">Investments @Model.Year</h6>
                    <h3 class="fw-bold">@Model.TotalInvestments.ToString("C")</h3>
                    <a href="@Url.Action("Index", "Investment")" class="btn btn-light btn-sm mt-2">View Details</a>
                </div>
            </div>
        </div>

    </div>

    <!-- Charts Section -->
    <div class="row g-4">

        <div class="col-md-6">
            <div class="card shadow-sm">
                <div class="card-header fw-semibold">
                    Cash Flow
                </div>
                <div class="card-body chart_container">
                    <div id="cash_flow_chart_div" style="height:350px;"></div>
                </div>
            </div>
        </div>

        <div class="col-md-6">
            <div class="card shadow-sm">
                <div class="card-header fw-semibold">
                    Income vs Expenses
                </div>
                <div class="card-body chart_container">
                    <div id="diff_chart_div" style="height:350px;"></div>
                </div>
            </div>
        </div>

        <div class="col-md-12">
            <div class="card shadow-sm">
                <div class="card-header fw-semibold">
                    Investments Overview
                </div>
                <div class="card-body chart_container">
                    <div id="inv_chart_div" style="height:350px;"></div>
                </div>
            </div>
        </div>

    </div>

</div>

<script src="~/js/charts.js"></script>
<script>
    var year = @Model.Year;
    drawChart(
        @Html.Raw(Json.Serialize(Model.MonthNames)),
        @Html.Raw(Json.Serialize(Model.MonthlyIncome)),
        @Html.Raw(Json.Serialize(Model.MonthlyExpenses)),
        @Html.Raw(Json.Serialize(Model.MonthlyInvestments))
    );
</script>