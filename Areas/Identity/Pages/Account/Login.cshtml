</div>

<script>
    function togglePassword(button) {
        const field = document.getElementById("passwordField");
        if (field.type === "password") {
            field.type = "text";
            button.innerText = "Hide";
        } else {
            field.type = "password";
            button.innerText = "Show";
        }
    }
</script>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
