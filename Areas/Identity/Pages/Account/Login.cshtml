@page
@model LoginModel

@{
    ViewData["Title"] = "Log in";
}

<h1 class="text-center mb-4">@ViewData["Title"]</h1>

<div class="row justify-content-center">
    <div class="col-md-5 col-lg-4">
        <div class="card shadow-sm border-0">
            <div class="card-body p-4">

                <form id="account" method="post" novalidate>

                    <div asp-validation-summary="ModelOnly"
                         class="alert alert-danger"
                         role="alert">
                    </div>

                    <!-- Email -->
                    <div class="form-floating mb-3">
                        <input asp-for="Input.Email"
                               value="admin@budget.com"
                               class="form-control"
                               autocomplete="username"
                               placeholder="name@example.com"
                               aria-required="true" />
                        <label asp-for="Input.Email">Email address</label>
                        <span asp-validation-for="Input.Email" class="text-danger small"></span>
                    </div>

                    <!-- Password -->
                    <div class="form-floating mb-3 position-relative">
                        <input asp-for="Input.Password"
                               type="password"
                               class="form-control"
                               id="passwordField"
                               value="Budget123!"
                               autocomplete="current-password"
                               placeholder="Password"
                               aria-required="true" />

                        <label asp-for="Input.Password">Password</label>

                        <!-- Toggle button -->
                        <button type="button"
                                class="btn btn-sm btn-outline-secondary position-absolute top-50 end-0 translate-middle-y me-2"
                                onclick="togglePassword(this)"
                                tabindex="-1">
                            Show
                        </button>

                        <span asp-validation-for="Input.Password" class="text-danger small"></span>
                    </div>

                    <!-- Remember me + Forgot -->
                    <div class="d-flex justify-content-between align-items-center mb-3">
                        <div class="form-check">
                            <input class="form-check-input"
                                   asp-for="Input.RememberMe" />
                            <label class="form-check-label"
                                   asp-for="Input.RememberMe">
                                Remember me
                            </label>
                        </div>

                        <a id="forgot-password"
                           asp-page="./ForgotPassword"
                           class="small">
                            Forgot password?
                        </a>
                    </div>

                    <!-- Submit -->
                    <div class="d-grid mb-3">
                        <button id="login-submit"
                                type="submit"
                                class="btn btn-primary btn-lg">
                            Log in
                        </button>
                    </div>

                    <!-- Register -->
                    <div class="text-center">
                        <span class="text-muted small">Don't have an account?</span><br />
                        <a asp-page="./Register"
                           asp-route-returnUrl="@Model.ReturnUrl">
                            Create one
                        </a>
                    </div>

                </form>
            </div>
        </div>
    </div>
