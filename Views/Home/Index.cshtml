@model MonthlySummaryViewModel

@{
    ViewData["Title"] = "Home Page";
    var years = ViewBag.AvailableYears as List<int>;
}

<link rel="stylesheet" href="~/css/home.css" />
<script type="text/javascript" src="https://www.gstatic.com/charts/loader.js"></script>

<!-- Year selector -->
<form method="get" id="yearForm">
    <label for="yearSelect">Select Year:</label>
    <select asp-for="Year"
            asp-items="@(new SelectList(years, Model.Year))"
            id="yearSelect"
            onchange="this.form.submit()">
    </select>
</form>

<div class="row">
    <div class="col-md-4">
        <div class="card text-white bg-success mb-3">
            <div class="card-body">
                <h5 class="card-title">Total Income @Model.Year</h5>
                <p class="card-text">@Model.TotalIncome.ToString("C")</p>
                <a href="@Url.Action("Index", "Income")" class="btn btn-light btn-sm">View Details</a>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card text-white bg-danger mb-3">
            <div class="card-body">
                <h5 class="card-title">Total Expenses @Model.Year</h5>
                <p class="card-text">@Model.TotalExpenses.ToString("C")</p>
                <a href="@Url.Action("Index", "Expense")" class="btn btn-light btn-sm">View Details</a>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card text-white bg-info mb-3">
            <div class="card-body">
                <h5 class="card-title">Investments @Model.Year</h5>
                <p class="card-text">@Model.TotalInvestments.ToString("C")</p>
                <a href="@Url.Action("Index", "Investment")" class="btn btn-light btn-sm">View Details</a>
            </div>
        </div>
    </div>

    <div class="chart_container">
        <div class="chart_div" id="cash_flow_chart_div"></div>
    </div>
    <div class="chart_container" style="margin-top: 30px;">
        <div class="chart_div" id="diff_chart_div"></div>
    </div>
    <div class="chart_container" style="margin-top: 30px;">
        <div class="chart_div" id="inv_chart_div"></div>
    </div>
</div>

<script src="~/js/charts.js"></script>
<script>
    var year = @Model.Year;
    drawChart(
        @Html.Raw(Json.Serialize(Model.MonthNames)),
        @Html.Raw(Json.Serialize(Model.MonthlyIncome)),
        @Html.Raw(Json.Serialize(Model.MonthlyExpenses)),
        @Html.Raw(Json.Serialize(Model.MonthlyInvestments))
    );
</script>